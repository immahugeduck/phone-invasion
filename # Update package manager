# Update package manager
sudo apt-get update

# Install Swift
sudo apt-get install -y swift

# Verify installation
swift --version

# Navigate to SHIELD-AI directory
cd /workspaces/phone-invasion/SHIELD-AI

# Initialize the Swift package (or create a Package.swift manually)
swift package init --name SHIELD-AI --type library

# Build it
swift build

# Run the executable (if applicable)
swift run